@page
@model MedAppWeb.Pages.Admin.PacientesModel
@{
    ViewData["Title"] = "Gestión de Pacientes";
}

<div class="page-heading">
    <div>
        <span class="eyebrow">Administración</span>
        <h1>Gestión de pacientes</h1>
        <p>Mantén actualizados los datos de contacto y documentos.</p>
    </div>
    <button onclick="mostrarFormulario()" class="btn btn-primary">Agregar paciente</button>
</div>

<div id="formulario" style="display:none;" class="form-panel">
    <input type="hidden" id="pacienteId" />
    <div class="row g-3">
        <div class="col-md-4"><label class="form-label">Nombre</label><input class="form-control" id="nombre" placeholder="Ej. Luis Torres" /></div>
        <div class="col-md-4"><label class="form-label">DNI</label><input class="form-control" id="dni" placeholder="Documento" /></div>
        <div class="col-md-4"><label class="form-label">Teléfono</label><input class="form-control" id="telefono" placeholder="Ej. 999 999 999" /></div>
    </div>
    <div class="form-actions">
        <button onclick="guardar()" class="btn btn-success">Guardar</button>
        <button onclick="cancelar()" class="btn btn-light">Cancelar</button>
    </div>
</div>

<div class="data-panel">
    <div class="table-responsive">
        <table class="table align-middle data-table">
            <thead><tr><th>Nombre</th><th>DNI</th><th>Teléfono</th><th class="text-end">Acciones</th></tr></thead>
            <tbody id="tablaPacientes"></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        const apiUrl = "/api/Pacientes";

        async function cargar() {
            const res = await fetch(apiUrl);
            const data = await res.json();
            let html = "";
            if (data.length === 0) {
                html = "<tr><td colspan='4' class='empty-state'>No hay pacientes registrados</td></tr>";
            } else {
                data.forEach(p => {
                    html += `<tr>
                        <td><strong>${p.nombre}</strong></td><td>${p.dni}</td><td>${p.telefono}</td>
                        <td class="text-end">
                            <button class="btn btn-warning btn-sm" onclick='editar("${p.id}","${p.nombre}","${p.dni}","${p.telefono}")'>Editar</button>
                            <button class="btn btn-outline-danger btn-sm" onclick='eliminar("${p.id}")'>Eliminar</button>
                        </td></tr>`;
                });
            }
            document.getElementById("tablaPacientes").innerHTML = html;
        }

        function mostrarFormulario() {
            document.getElementById("formulario").style.display = "block";
            document.getElementById("pacienteId").value = "";
            document.getElementById("nombre").value = "";
            document.getElementById("dni").value = "";
            document.getElementById("telefono").value = "";
        }

        function cancelar() { document.getElementById("formulario").style.display = "none"; }

        function editar(id, nombre, dni, telefono) {
            document.getElementById("formulario").style.display = "block";
            document.getElementById("pacienteId").value = id;
            document.getElementById("nombre").value = nombre;
            document.getElementById("dni").value = dni;
            document.getElementById("telefono").value = telefono;
        }

        async function guardar() {
            const id = document.getElementById("pacienteId").value;
            const body = {
                nombre: document.getElementById("nombre").value,
                dni: document.getElementById("dni").value,
                telefono: document.getElementById("telefono").value,
                usuarioId: ""
            };
            if (id) {
                await fetch(`${apiUrl}/${id}`, { method: "PUT", headers: {"Content-Type":"application/json"}, body: JSON.stringify(body) });
            } else {
                await fetch(apiUrl, { method: "POST", headers: {"Content-Type":"application/json"}, body: JSON.stringify(body) });
            }
            cancelar();
            cargar();
        }

        async function eliminar(id) {
            if (confirm("¿Eliminar paciente?")) {
                await fetch(`${apiUrl}/${id}`, { method: "DELETE" });
                cargar();
            }
        }

        cargar();
    </script>
}
