@page
@model MedAppWeb.Pages.Admin.MedicosModel
@{
    ViewData["Title"] = "Gestión de Médicos";
}

<div class="page-heading">
    <div>
        <span class="eyebrow">Administración</span>
        <h1>Gestión de médicos</h1>
        <p>Organiza el directorio médico y sus especialidades.</p>
    </div>
    <button onclick="mostrarFormulario()" class="btn btn-primary">Agregar médico</button>
</div>

<div id="formulario" style="display:none;" class="form-panel">
    <input type="hidden" id="medicoId" />
    <div class="row g-3">
        <div class="col-md-4"><label class="form-label">Nombre</label><input class="form-control" id="nombre" placeholder="Ej. Ana Ramos" /></div>
        <div class="col-md-4"><label class="form-label">DNI</label><input class="form-control" id="dni" placeholder="Documento" /></div>
        <div class="col-md-4"><label class="form-label">Especialidad</label><input class="form-control" id="especialidad" placeholder="Ej. Cardiología" /></div>
    </div>
    <div class="form-actions">
        <button onclick="guardar()" class="btn btn-success">Guardar</button>
        <button onclick="cancelar()" class="btn btn-light">Cancelar</button>
    </div>
</div>

<div class="data-panel">
    <div class="table-responsive">
        <table class="table align-middle data-table">
            <thead><tr><th>Nombre</th><th>DNI</th><th>Especialidad</th><th class="text-end">Acciones</th></tr></thead>
            <tbody id="tablaMedicos"></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        const apiUrl = "/api/Medicos";

        async function cargar() {
            try {
                const res = await fetch(apiUrl);
                if (!res.ok) throw new Error("Error al cargar");
                const data = await res.json();
                let html = "";
                if (data.length === 0) {
                    html = "<tr><td colspan='4' class='empty-state'>No hay médicos registrados</td></tr>";
                } else {
                    data.forEach(m => {
                        html += `<tr>
                            <td><strong>${m.nombre}</strong></td><td>${m.dni}</td><td><span class="status-pill info">${m.especialidad}</span></td>
                            <td class="text-end">
                                <button class="btn btn-warning btn-sm" onclick='editar("${m.id}","${m.nombre}","${m.dni}","${m.especialidad}")'>Editar</button>
                                <button class="btn btn-outline-danger btn-sm" onclick='eliminar("${m.id}")'>Eliminar</button>
                            </td></tr>`;
                    });
                }
                document.getElementById("tablaMedicos").innerHTML = html;
            } catch(e) {
                document.getElementById("tablaMedicos").innerHTML = "<tr><td colspan='4' class='empty-state'>Error al cargar datos</td></tr>";
                console.error(e);
            }
        }

        function mostrarFormulario() {
            document.getElementById("formulario").style.display = "block";
            document.getElementById("medicoId").value = "";
            document.getElementById("nombre").value = "";
            document.getElementById("dni").value = "";
            document.getElementById("especialidad").value = "";
        }

        function cancelar() { document.getElementById("formulario").style.display = "none"; }

        function editar(id, nombre, dni, especialidad) {
            document.getElementById("formulario").style.display = "block";
            document.getElementById("medicoId").value = id;
            document.getElementById("nombre").value = nombre;
            document.getElementById("dni").value = dni;
            document.getElementById("especialidad").value = especialidad;
        }

        async function guardar() {
            const id = document.getElementById("medicoId").value;
            const body = {
                nombre: document.getElementById("nombre").value,
                dni: document.getElementById("dni").value,
                especialidad: document.getElementById("especialidad").value,
                usuarioId: ""
            };
            if (id) {
                await fetch(`${apiUrl}/${id}`, { method: "PUT", headers: {"Content-Type":"application/json"}, body: JSON.stringify(body) });
            } else {
                await fetch(apiUrl, { method: "POST", headers: {"Content-Type":"application/json"}, body: JSON.stringify(body) });
            }
            cancelar();
            cargar();
        }

        async function eliminar(id) {
            if (confirm("¿Eliminar médico?")) {
                await fetch(`${apiUrl}/${id}`, { method: "DELETE" });
                cargar();
            }
        }

        cargar();
    </script>
}
