<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MedApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MedAppWeb.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="app-header">
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand app-brand" asp-area="" asp-page="/Index">
                    <span class="brand-mark">M</span>
                    <span>MedApp</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Abrir navegación">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse justify-content-end">
                    <ul class="navbar-nav app-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Admin/Medicos">Médicos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Admin/Pacientes">Pacientes</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Admin/Citas">Citas</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="app-shell">
        <main role="main" class="container py-4 py-lg-5">
            @RenderBody()
        </main>
    </div>
    <footer class="footer">
        <div class="container">
            <span>&copy; 2026 MedApp</span>
            <a asp-area="" asp-page="/Privacy">Privacidad</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
